{
  "entities": {
    "Writer": {
      "title": "Digital Writer",
      "description": "Stable dynamic human tone persona profile",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier" },
        "name": { "type": "string", "description": "Writer display name" },
        "voiceStyle": { "type": "string", "description": "Narrative style and voice descriptor" },
        "bio": { "type": "string", "description": "Brief biography of the expert" },
        "customPromptInstruction": { "type": "string", "description": "Explicit prompt system rules for LLM behavior" }
      },
      "required": ["id", "name", "voiceStyle", "customPromptInstruction"]
    },
    "RssFeed": {
      "title": "RSS Feed source",
      "description": "Monitored automated breaking catalog reference",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique feed ID" },
        "name": { "type": "string", "description": "Display name of the publication" },
        "url": { "type": "string", "format": "uri", "description": "Full target XML RSS feed endpoint" },
        "niche": { "type": "string", "enum": ["hollywood", "sports", "tech"], "description": "Platform target vertical" },
        "isActive": { "type": "boolean", "description": "Active sync status" },
        "lastSynced": { "type": "string", "description": "ISO timestamp of last crawl" }
      },
      "required": ["id", "name", "url", "niche", "isActive"]
    },
    "Article": {
      "title": "SaaS Article Draft",
      "description": "Synthesized article draft complete with original editorial validation and SEO optimization",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique draft identifier" },
        "niche": { "type": "string", "description": "Associated niche vertical" },
        "sourceTitle": { "type": "string", "description": "Original raw news item title" },
        "sourceLink": { "type": "string", "description": "Link back to verified news source" },
        "authorId": { "type": "string", "description": "Matched digital human writer tone ID" },
        "title": { "type": "string", "description": "Draft high-concept title optimized" },
        "content": { "type": "string", "description": "Pristine markdown formatted prose" },
        "createdAt": { "type": "string", "description": "Draft creation timestamp" },
        "originalImageUrl": { "type": "string", "description": "Curated or AI generated visual backdrop link" },
        "seo": {
          "type": "object",
          "description": "SEO indexing factors and parameters"
        },
        "wordpressPush": {
          "type": "object",
          "description": "WordPress distribution tracking properties"
        }
      },
      "required": ["id", "niche", "authorId", "title", "content", "createdAt"]
    },
    "SaaSSettings": {
      "title": "SaaS Platform Settings",
      "description": "Model configuration parameters and secure API tokens proxy configurations",
      "type": "object",
      "properties": {
        "modelSettings": {
          "type": "object",
          "description": "Model configurations inside the platform"
        },
        "wordpress": {
          "type": "object",
          "description": "WordPress destinations configured"
        }
      },
      "required": ["modelSettings", "wordpress"]
    },
    "Notification": {
      "title": "Audit Activity Log Notification",
      "description": "Log notification stored in real-time history",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique notification ID" },
        "type": { "type": "string", "description": "Level or category" },
        "title": { "type": "string", "description": "Headline" },
        "message": { "type": "string", "description": "Activity details" },
        "timestamp": { "type": "string", "description": "Execution timestamp" },
        "read": { "type": "boolean", "description": "Acknowledge flag" }
      },
      "required": ["id", "type", "title", "message", "timestamp", "read"]
    },
    "SuggestedSource": {
      "title": "Crawl Suggested News Item Source",
      "description": "Pre-classified RSS source opportunity item",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier hash" },
        "title": { "type": "string", "description": "Headline" },
        "url": { "type": "string", "description": "Main target seed article link" },
        "processingStatus": { "type": "string", "description": "Review status" },
        "opportunityScore": { "type": "number", "description": "Refined scored indexing weight" },
        "pipeline": { "type": "string", "description": "Pipeline execution strategy tier" },
        "manualReview": { "type": "boolean", "description": "Gate required flag" }
      },
      "required": ["id", "title", "url", "opportunityScore", "pipeline", "manualReview", "processingStatus"]
    },
    "Candidate": {
      "title": "Digital Writer Candidate",
      "description": "Talent pool of digital writer candidates ready to join the publishing board",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique database identifier" },
        "name": { "type": "string", "description": "Catchy journalist name" },
        "niche": { "type": "string", "description": "Focus niche vertical" },
        "competitor": { "type": "string", "description": "Target competitor publication" },
        "avatar": { "type": "string", "description": "Headshot Unsplash image URL" },
        "skills": {
          "type": "array",
          "description": "Specialized core skills list"
        },
        "voiceStyle": { "type": "string", "description": "Meticulous voice style profile" },
        "bio": { "type": "string", "description": "Bio description details" },
        "customPromptInstruction": { "type": "string", "description": "Style alignment prompt constraints" }
      },
      "required": ["id", "name", "niche", "competitor", "avatar", "skills", "voiceStyle", "bio", "customPromptInstruction"]
    },
    "Skill": {
      "title": "Platform Skill",
      "description": "Dynamic editing or orchestration skill configured in the platform",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier" },
        "name": { "type": "string", "description": "Display name of the skill" },
        "niche": { "type": "string", "description": "Applicable niche filter" },
        "directive": { "type": "string", "description": "Detailed skill instruction text" }
      },
      "required": ["id", "name", "niche", "directive"]
    },
    "Niche": {
      "title": "Platform Niche",
      "description": "Custom user-defined niche for specialized writing and rewriting",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique slug ID" },
        "name": { "type": "string", "description": "Display name of the niche" },
        "tagline": { "type": "string", "description": "Slogan or purpose statement" },
        "primaryColor": { "type": "string" },
        "accentColor": { "type": "string" },
        "fontFamily": { "type": "string" },
        "themeStyle": { "type": "string" }
      },
      "required": ["id", "name", "tagline", "primaryColor", "accentColor", "fontFamily", "themeStyle"]
    },
    "FinalArticlePackage": {
      "title": "Final Article Package",
      "description": "Immutable publishing package for an article",
      "type": "object",
      "properties": {
        "packageId": { "type": "string" },
        "articleId": { "type": "string" },
        "workflowRunId": { "type": "string" },
        "packageVersion": { "type": "number" },
        "createdAt": { "type": "string" },
        "createdBy": { "type": "string" },
        "packageStatus": { "type": "string" }
      },
      "required": ["packageId", "articleId", "createdAt", "packageStatus"]
    },
    "PhaseDAuditEvent": {
      "title": "Phase D Audit Event",
      "description": "State change audit events for editorial pipelines",
      "type": "object",
      "properties": {
        "packageId": { "type": "string" },
        "eventType": { "type": "string" },
        "action": { "type": "string" },
        "sanitizedEvidence": { "type": "string" },
        "timestamp": { "type": "string" }
      },
      "required": ["packageId", "eventType", "action", "timestamp"]
    },
    "PublishingJob": {
      "title": "Publishing Job",
      "description": "Queue publishing job to WordPress with lease logic",
      "type": "object",
      "properties": {
        "jobId": { "type": "string" },
        "packageId": { "type": "string" },
        "targetSiteId": { "type": "string" },
        "status": { "type": "string" },
        "leaseToken": { "type": "string" },
        "runCount": { "type": "number" },
        "maxRetries": { "type": "number" },
        "nextRunAt": { "type": "string" }
      },
      "required": ["jobId", "packageId", "targetSiteId", "status", "runCount", "maxRetries", "nextRunAt"]
    },
    "AuditLog": {
      "title": "System Audit Log",
      "description": "Historical audit log record for security, errors, and system activity",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique log record ID" },
        "timestamp": { "type": "string", "description": "ISO timestamp of the event" },
        "type": { "type": "string", "description": "Category/type of log event" },
        "details": { "type": "object", "description": "Arbitrary details or payload of the event" }
      },
      "required": ["id", "timestamp", "type", "details"]
    },
    "CustomDiscoveredFeed": {
      "title": "Custom Discovered RSS Feed",
      "description": "A customized feed item discovered dynamically using keyword targeting",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique feed ID" },
        "name": { "type": "string", "description": "Display name of the discovered feed" },
        "url": { "type": "string", "format": "uri", "description": "Discovered feed URL" },
        "description": { "type": "string", "description": "Feed description" },
        "niche": { "type": "string", "description": "Associated niche slug ID" },
        "rank": { "type": "number", "description": "Search discovery relevance rank" },
        "isCustom": { "type": "boolean", "description": "Explicit custom discovery status flag" }
      },
      "required": ["id", "name", "url", "niche", "isCustom"]
    }
  },
  "firestore": {
    "auditLogs/{logId}": {
      "schema": "AuditLog",
      "description": "System audit and security event logs"
    },
    "customDiscoveredFeeds/{feedId}": {
      "schema": "CustomDiscoveredFeed",
      "description": "Dynamically discovered high-opportunity RSS feeds"
    },
    "writers/{writerId}": {
      "schema": "Writer",
      "description": "Guild of persistent human writing profiles for agent orchestration"
    },
    "feeds/{feedId}": {
      "schema": "RssFeed",
      "description": "RSS catalog source references"
    },
    "articles/{articleId}": {
      "schema": "Article",
      "description": "Durable content drafts"
    },
    "settings/saas": {
      "schema": "SaaSSettings",
      "description": "Global SaaS system parameters"
    },
    "notifications/{notifId}": {
      "schema": "Notification",
      "description": "Real-time activity messages and platform audits"
    },
    "suggestedSources/{sourceId}": {
      "schema": "SuggestedSource",
      "description": "Live opportunities loaded and suggested for rewriting pipeline runs"
    },
    "candidates/{candidateId}": {
      "schema": "Candidate",
      "description": "Talent pool of digital writers awaiting hire to board"
    },
    "skills/{skillId}": {
      "schema": "Skill",
      "description": "Durable digital skills mapped for rewrite loops"
    },
    "niches/{nicheId}": {
      "schema": "Niche",
      "description": "Custom digital niches created dynamically"
    },
    "phase_d_packages/{packageId}": {
      "schema": "FinalArticlePackage",
      "description": "Immutable publishing packages generated in Phase D"
    },
    "phase_d_audits/{auditId}": {
      "schema": "PhaseDAuditEvent",
      "description": "Audit trails of packaging decisions"
    },
    "publishing_queue/{jobId}": {
      "schema": "PublishingJob",
      "description": "WordPress distribution and queue execution jobs"
    }
  }
}
