rules_version = '2';
service cloud.firestore {
  match /databases/ai-studio-767d7b73-69cd-4989-abdf-e59b01aaad79/documents {
    // Helper functions
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    match /writers/{writerId} {
      allow read, write: if true;
    }

    match /feeds/{feedId} {
      allow read, write: if true;
    }

    match /articles/{articleId} {
      allow read, write: if true;
    }

    match /settings/{docId} {
      allow read, write: if true;
    }

    match /notifications/{notifId} {
      allow read, write: if true;
    }

    match /suggestedSources/{sourceId} {
      allow read, write: if true;
    }

    match /candidates/{candidateId} {
      allow read, write: if true;
    }

    match /skills/{skillId} {
      allow read, write: if true;
    }

    match /niches/{nicheId} {
      allow read, write: if true;
    }

    match /customDiscoveredFeeds/{feedId} {
      allow read, write: if true;
    }

    match /phase_d_packages/{packageId} {
      allow read, write: if true;
    }

    match /phase_d_audits/{auditId} {
      allow read, write: if true;
    }

    match /publishing_queue/{jobId} {
      allow read, write: if true;
    }

    match /auditLogs/{logId} {
      allow read, write: if true;
    }
  }
}
