rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation helpers
    function isValidWriter(data) {
      return data.id is string && data.name is string;
    }

    function isValidFeed(data) {
      return data.id is string && data.name is string && data.url is string;
    }

    function isValidArticle(data) {
      return data.id is string && data.title is string && data.content is string;
    }

    function isValidNotification(data) {
      return data.id is string && data.title is string && data.message is string;
    }

    function isValidSuggestedSource(data) {
      return data.id is string && data.title is string && data.url is string;
    }

    function isValidCandidate(data) {
      return data.id is string && data.name is string && data.niche is string;
    }

    function isValidSkill(data) {
      return data.id is string && data.name is string && data.directive is string;
    }

    function isValidNiche(data) {
      return data.id is string && data.name is string;
    }

    // Match patterns
    match /writers/{writerId} {
      allow read: if true;
      allow create, update: if isValidId(writerId) && isValidWriter(incoming());
      allow delete: if isValidId(writerId);
    }

    match /feeds/{feedId} {
      allow read: if true;
      allow create, update: if isValidId(feedId) && isValidFeed(incoming());
      allow delete: if isValidId(feedId);
    }

    match /articles/{articleId} {
      allow read: if true;
      allow create: if isValidId(articleId) && isValidArticle(incoming());
      allow update: if isValidId(articleId) && isValidArticle(incoming())
        && (!incoming().keys().hasAny(['createdAt']) || incoming().createdAt == existing().createdAt);
      allow delete: if isValidId(articleId);
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isValidId(docId);
    }

    match /notifications/{notifId} {
      allow read: if true;
      allow create, update: if isValidId(notifId) && isValidNotification(incoming());
      allow delete: if isValidId(notifId);
    }

    match /suggestedSources/{sourceId} {
      allow read: if true;
      allow create, update: if isValidId(sourceId) && isValidSuggestedSource(incoming());
      allow delete: if isValidId(sourceId);
    }

    match /candidates/{candidateId} {
      allow read: if true;
      allow create, update: if isValidId(candidateId) && isValidCandidate(incoming());
      allow delete: if isValidId(candidateId);
    }

    match /skills/{skillId} {
      allow read: if true;
      allow create, update: if isValidId(skillId) && isValidSkill(incoming());
      allow delete: if isValidId(skillId);
    }

    match /niches/{nicheId} {
      allow read: if true;
      allow create, update: if isValidId(nicheId) && isValidNiche(incoming());
      allow delete: if isValidId(nicheId);
    }

    match /phase_d_packages/{packageId} {
      allow read: if true;
      allow write: if isValidId(packageId);
    }

    match /phase_d_audits/{auditId} {
      allow read: if true;
      allow write: if false;
    }

    match /publishing_queue/{jobId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
