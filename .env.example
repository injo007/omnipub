# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# OPENROUTER_API_KEY: Optional fallback key to use OpenRouter models when Gemini quota is exceeded
OPENROUTER_API_KEY=""

# MINIMAX_API_KEY: Credentials to connect to the MiniMax gateway engine directly
MINIMAX_API_KEY=""

# CREDENTIALS_VAULT_KEY: Symmetrically encrypts WordPress application credentials
CREDENTIALS_VAULT_KEY="fb3ac64b732d4e7f9188a3b50c6d9bc5"

# --- PostgreSQL Connection Parameters ---
# Hostname of the self-hosted PostgreSQL instance (defaults to "db" in Docker Compose, or "localhost" on host)
PGHOST="db"
# Port of the PostgreSQL instance
PGPORT="5432"
# Database name to connect to
PGDATABASE="editorial_db"
# PostgreSQL username (required to connect and manage tables)
PGUSER="postgres"
# PostgreSQL password (required to connect, triggers Postgres mode)
PGPASSWORD=""


