# Optional native Gemini provider key.
GEMINI_API_KEY=""

APP_URL="https://publish.example.com"

# Required when MiniMax-M3 and the fallback model are routed through OpenRouter.
OPENROUTER_API_KEY=""

# Alternatively, configure the native MiniMax gateway key.
MINIMAX_API_KEY=""

# CREDENTIALS_VAULT_KEY: Symmetrically encrypts WordPress application credentials
# IMPORTANT: Must be exactly 32 characters long. Replace with your own secure key in production!
# If not set, secrets will be stored in plaintext (not recommended).
CREDENTIALS_VAULT_KEY=""

# --- PostgreSQL Connection Parameters ---
# PostgreSQL is mandatory in staging and production.
PGHOST="localhost"       # or "db" when running in Docker Compose
PGPORT="5432"
PGDATABASE="editorial_db"
PGUSER="postgres"
PGPASSWORD="REPLACE_WITH_A_LONG_RANDOM_PASSWORD"
POSTGRES_REQUIRED="true"

# Optional self-hosted API authentication. The current browser UI expects this
# to remain false unless a reverse proxy injects the bearer token.
AUTH_REQUIRED="false"
APP_API_TOKEN=""
BYPASS_AUTH="false"

